<Window x:Class="OBSController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OBS Controller"
        Height="500" Width="500"
        MinHeight="500" MinWidth="500"
        MaxHeight="500" MaxWidth="500"
        Background="#121212"
        Foreground="#e8e8e8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Stile bottone scene - OTTIMIZZATO -->
        <Style x:Key="SceneButton" TargetType="Button">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Foreground" Value="white"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF8555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DD5A2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FancyCheckBox Base -->
        <Style x:Key="FancyCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#444444" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#FF6B35"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckCircle" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Colorati per ciascuno -->
        <Style x:Key="CheckPTZ" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#4A90E2" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#4A90E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckJWLibrary" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#7CB342" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#7CB342"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckZoom" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#E64980" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#E64980"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckOnlyt" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#FFA726" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#FFA726"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- LAYOUT PRINCIPALE - COMPATTO E VELOCE -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR: Settings + Status -->
        <Border Grid.Row="0" Background="#0a0a0a" BorderBrush="#333333" BorderThickness="0,0,0,1">
            <Grid Margin="12,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Name="BtnSettings" Grid.Column="0"
                        Content="⚙ Impostazioni"
                        Background="#1a1a1a" Foreground="#FF6B35"
                        BorderThickness="0" Padding="12,6" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnSettings_Click"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Name="StatusDot" Width="9" Height="9"
                             Fill="#cc3333" Margin="0,0,8,0"/>
                    <TextBlock Name="StatusText" Text="Disconnesso"
                               Foreground="#888888" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT: Left Panel (Scenes + Status) | Right Panel (Preview) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Scene Buttons + Status Checks -->
            <StackPanel Grid.Column="0" Background="#0a0a0a" Margin="12,12,0,12" VerticalAlignment="Top">

                <!-- SCENE BUTTONS -->
                <TextBlock Text="SCENE" Foreground="#666666" FontSize="9" FontWeight="Bold" Margin="2,0,0,2" Opacity="0.8"/>
                
                <Button Name="BtnScene4" Content="📺 Multimedia" Style="{StaticResource SceneButton}"
                        Tag="Multimedia" Click="BtnScene_Click"/>
                <Button Name="BtnScene1" Content="🎤 Centrale" Style="{StaticResource SceneButton}"
                        Tag="Centrale" Click="BtnScene_Click"/>
                <Button Name="BtnScene2" Content="👥 Doppio" Style="{StaticResource SceneButton}"
                        Tag="Doppio" Click="BtnScene_Click"/>
                <Button Name="BtnScene3" Content="📊 Dimostrazione" Style="{StaticResource SceneButton}"
                        Tag="Dimostrazione" Click="BtnScene_Click"/>

                <Separator Background="#222222" Margin="2,4"/>

                <!-- STATUS CHECKS -->
                <TextBlock Text="MONITOR" Foreground="#666666" FontSize="9" FontWeight="Bold" Margin="2,0,0,2" Opacity="0.8"/>

                <CheckBox Name="ChkPTZ" IsEnabled="False" Style="{StaticResource CheckPTZ}">
                    <TextBlock Text="Telecamera PTZ" Foreground="#e8e8e8"/>
                </CheckBox>

                <CheckBox Name="ChkJWLibrary" IsEnabled="False" Style="{StaticResource CheckJWLibrary}">
                    <TextBlock Text="JW Library" Foreground="#e8e8e8"/>
                </CheckBox>

                <CheckBox Name="ChkZoom" IsEnabled="False" Style="{StaticResource CheckZoom}">
                    <TextBlock Text="Zoom" Foreground="#e8e8e8"/>
                </CheckBox>

                <CheckBox Name="ChkOnlyt" IsEnabled="False" Style="{StaticResource CheckOnlyt}">
                    <TextBlock Text="Onlyt" Foreground="#e8e8e8"/>
                </CheckBox>

            </StackPanel>

            <!-- DIVIDER -->
            <Border Grid.Column="1" Background="#222222" Margin="0,10"/>

            <!-- RIGHT PANEL: Preview Webcam Virtuale -->
            <Grid Grid.Column="2" Background="#0a0a0a" Margin="12,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    
                    <!-- Preview Border -->
                    <Border Background="#000000" BorderBrush="#333333" BorderThickness="1"
                            Width="270" Height="270" CornerRadius="4" 
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid>
                            <Image Name="PreviewImage" Stretch="UniformToFill"/>
                            <TextBlock Name="PreviewPlaceholder" Text="📹 Preview"
                                       Foreground="#444444" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Virtual Camera Status Indicator -->
                    <Border Background="#1a1a1a" BorderBrush="#333333" BorderThickness="1" 
                            Padding="10,8" CornerRadius="3" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Name="VCamStatusDot" Width="9" Height="9" Fill="#cc3333"/>
                            <TextBlock Name="VCamStatusText" Text="Webcam: Spenta" Foreground="#e8e8e8" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Warning Overlay -->
                    <Border Name="VCamWarning" Background="#FF6B35" Padding="8,6" CornerRadius="3" 
                            HorizontalAlignment="Center" Visibility="Visible">
                        <TextBlock Text="⚠ Webcam non avviata"
                                   Foreground="white" FontSize="10" FontWeight="SemiBold"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Grid>

        </Grid>

    </Grid>
</Window>
