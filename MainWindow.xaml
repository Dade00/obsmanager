<Window x:Class="OBSController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OBS Controller"
        Height="600" Width="550"
        MinHeight="600" MinWidth="550"
        MaxHeight="600" MaxWidth="550"
        Background="#121212"
        Foreground="#e8e8e8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Stile bottone scene - OTTIMIZZATO -->
        <Style x:Key="SceneButton" TargetType="Button">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Foreground" Value="white"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF8555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DD5A2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stile bottone VCam Toggle -->
        <ControlTemplate x:Key="ButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- FancyCheckBox Base -->
        <Style x:Key="FancyCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#444444" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#FF6B35"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckCircle" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Colorati per ciascuno -->
        <Style x:Key="CheckPTZ" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#4A90E2" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#4A90E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckJWLibrary" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#7CB342" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#7CB342"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckZoom" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#E64980" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#E64980"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckOnlyt" TargetType="CheckBox" BasedOn="{StaticResource FancyCheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="CheckCircle" Width="12" Height="12"
                                    Fill="#FFA726" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Fill" Value="#FFA726"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- LAYOUT PRINCIPALE: Preview top, Controls bottom -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR: Settings + Status -->
        <Border Grid.Row="0" Background="#0a0a0a" BorderBrush="#333333" BorderThickness="0,0,0,1">
            <Grid Margin="12,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Name="BtnSettings" Grid.Column="0"
                        Content="⚙ Impostazioni"
                        Background="#1a1a1a" Foreground="#FF6B35"
                        BorderThickness="0" Padding="12,6" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnSettings_Click"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Name="StatusDot" Width="9" Height="9"
                             Fill="#cc3333" Margin="0,0,8,0"/>
                    <TextBlock Name="StatusText" Text="Disconnesso"
                               Foreground="#888888" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PREVIEW SECTION: Center preview only -->
        <Border Grid.Row="1" Background="#0a0a0a" Padding="12,10,12,10" HorizontalAlignment="Center">
            <!-- Preview Border - 16:9 aspect ratio -->
            <Border Background="#000000" BorderBrush="#333333" BorderThickness="1"
                    Width="410" Height="230" CornerRadius="4">
                <Grid>
                    <Image Name="PreviewImage" Stretch="UniformToFill"/>
                    <TextBlock Name="PreviewPlaceholder" Text="📹 Preview"
                               Foreground="#444444" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Border>

        <!-- BOTTOM PANEL: Scenes left + Monitor right -->
        <Grid Grid.Row="2" Background="#0a0a0a">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: SCENE BUTTONS (2x2 grid) + Virtual Cam Status -->
            <StackPanel Grid.Column="0" Margin="14,12,6,14" VerticalAlignment="Top">

                <!-- SCENE BUTTONS -->
                <TextBlock Text="SCENE" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,8" Opacity="0.8"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Name="BtnScene4" Content="📺 Multimedia"
                            Style="{StaticResource SceneButton}" Tag="Multimedia" Click="BtnScene_Click" Margin="0,0,3,3"/>
                    <Button Grid.Row="0" Grid.Column="1" Name="BtnScene1" Content="🎤 Centrale"
                            Style="{StaticResource SceneButton}" Tag="Centrale" Click="BtnScene_Click" Margin="3,0,0,3"/>
                    <Button Grid.Row="1" Grid.Column="0" Name="BtnScene2" Content="👥 Doppio"
                            Style="{StaticResource SceneButton}" Tag="Doppio" Click="BtnScene_Click" Margin="0,3,3,0"/>
                    <Button Grid.Row="1" Grid.Column="1" Name="BtnScene3" Content="📊 Dimostrazione"
                            Style="{StaticResource SceneButton}" Tag="Dimostrazione" Click="BtnScene_Click" Margin="3,3,0,0"/>
                </Grid>

                <!-- Separator -->
                <Separator Background="#222222" Margin="0,0,0,12"/>

                <!-- VIRTUAL CAMERA CONTROL - PROMINENT -->
                <TextBlock Text="WEBCAM" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,8" Opacity="0.8"/>

                <!-- VCam Status Card -->
                <Border Background="#1a1a1a" BorderBrush="#333333" BorderThickness="1"
                        Padding="10,10" CornerRadius="4" Margin="0,0,0,8">
                    <StackPanel>
                        <!-- Status Indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Name="VCamStatusDot" Width="12" Height="12" Fill="#cc3333" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Name="VCamStatusText" Text="Spenta" Foreground="#FF6B35" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Action Button - Only shows when OFF -->
                        <Button Name="BtnToggleVCam" Content="▶ Avvia" Foreground="white" FontSize="12"
                                FontWeight="SemiBold" Background="#43A047" BorderThickness="0" 
                                Padding="0,10" Cursor="Hand" Click="BtnToggleVCam_Click"
                                Template="{DynamicResource ButtonTemplate}" Visibility="Visible"/>

                        <!-- Status message when ON -->
                        <TextBlock Name="VCamActiveMsg" Text="✓ Webcam avviata" Foreground="#43A047" 
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,0" TextAlignment="Center"
                                   Visibility="Collapsed"/>

                        <!-- Inline Warning - Only shows when OFF -->
                        <TextBlock Name="VCamWarning" Text="⚠ Non avviata" Foreground="#FF6B35" 
                                   FontSize="10" Margin="0,8,0,0" TextAlignment="Center"
                                   Visibility="Visible"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- DIVIDER -->
            <Border Grid.Column="1" Background="#222222" Margin="0,8"/>

            <!-- RIGHT: MONITOR INDICATORS -->
            <StackPanel Grid.Column="2" Margin="6,12,12,14" VerticalAlignment="Top">
                <TextBlock Text="MONITOR" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,8" Opacity="0.8"/>

                <CheckBox Name="ChkPTZ" IsEnabled="False" Style="{StaticResource CheckPTZ}" Margin="0,4">
                    <TextBlock Text="Telecamera" Foreground="#e8e8e8" FontSize="10"/>
                </CheckBox>

                <CheckBox Name="ChkJWLibrary" IsEnabled="False" Style="{StaticResource CheckJWLibrary}" Margin="0,4">
                    <TextBlock Text="JW Library" Foreground="#e8e8e8" FontSize="10"/>
                </CheckBox>

                <CheckBox Name="ChkZoom" IsEnabled="False" Style="{StaticResource CheckZoom}" Margin="0,4">
                    <TextBlock Text="Zoom" Foreground="#e8e8e8" FontSize="10"/>
                </CheckBox>

                <CheckBox Name="ChkOnlyt" IsEnabled="False" Style="{StaticResource CheckOnlyt}" Margin="0,4">
                    <TextBlock Text="Onlyt" Foreground="#e8e8e8" FontSize="10"/>
                </CheckBox>
            </StackPanel>

        </Grid>

    </Grid>
</Window>
