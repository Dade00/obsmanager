<Window x:Class="OBSController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OBS Controller"
        Height="680" Width="980"
        MinHeight="560" MinWidth="800"
        Background="#0D0D0D"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ── Colori base ──────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgMain"       Color="#0D0D0D"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#1A1A1A"/>
        <SolidColorBrush x:Key="BgInput"      Color="#242424"/>
        <SolidColorBrush x:Key="BgInputHover" Color="#2E2E2E"/>
        <SolidColorBrush x:Key="Accent"       Color="#FF6B35"/>
        <SolidColorBrush x:Key="AccentDim"    Color="#CC4A1A"/>
        <SolidColorBrush x:Key="Live"         Color="#E53935"/>
        <SolidColorBrush x:Key="Safe"         Color="#43A047"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E8E8E8"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#888888"/>
        <SolidColorBrush x:Key="Border"       Color="#333333"/>
        <SolidColorBrush x:Key="SceneActive"  Color="#FF6B35"/>

        <!-- ── Label sezione ────────────────────────────────────────────── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="9"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="#888888"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Margin"        Value="0,0,0,6"/>
            <Setter Property="TextTransform" Value="Uppercase"/>
        </Style>

        <!-- ── TextBox dark ─────────────────────────────────────────────── -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"        Value="#242424"/>
            <Setter Property="Foreground"        Value="#E8E8E8"/>
            <Setter Property="BorderBrush"       Value="#333333"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="8,5"/>
            <Setter Property="Height"            Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"        Value="#FF6B35"/>
            <Setter Property="SelectionBrush"    Value="#FF6B35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FF6B35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── PasswordBox dark ─────────────────────────────────────────── -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"        Value="#242424"/>
            <Setter Property="Foreground"        Value="#E8E8E8"/>
            <Setter Property="BorderBrush"       Value="#333333"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="8,5"/>
            <Setter Property="Height"            Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"        Value="#FF6B35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FF6B35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Pulsante primario arancione ──────────────────────────────── -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background"      Value="#FF6B35"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF8C5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CC4A1A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#444444"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Pulsante ghost (outline) ─────────────────────────────────── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="BorderBrush"     Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#666666"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#444444"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Voce della lista scene ────────────────────────────────────── -->
        <Style x:Key="SceneItem" TargetType="ListBoxItem">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="10,7"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="2,0,0,0"
                                BorderBrush="Transparent"
                                Margin="0,1"
                                CornerRadius="0,3,3,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1200"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6B35"/>
                                <Setter Property="Foreground" Value="#FF6B35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListBox scene ────────────────────────────────────────────── -->
        <Style x:Key="SceneListBox" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SceneItem}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

    </Window.Resources>

    <!-- ════════════════════ LAYOUT PRINCIPALE ════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- Barra superiore connessione -->
            <RowDefinition Height="54"/>
            <!-- Area principale -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── TOP BAR ────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#141414"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / titolo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="10" Height="10"
                             Fill="#E53935"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#E53935" BlurRadius="6" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="OBS"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#FF6B35"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" Controller"
                               FontSize="14" FontWeight="Light"
                               Foreground="#888888"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Parametri connessione -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                    <TextBlock Text="IP"
                               Foreground="#666666"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtIP"
                             Style="{StaticResource DarkTextBox}"
                             Text="localhost"
                             Width="120"
                             Margin="0,0,8,0"/>

                    <TextBlock Text="PORTA"
                               Foreground="#666666"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtPort"
                             Style="{StaticResource DarkTextBox}"
                             Text="4455"
                             Width="60"
                             Margin="0,0,8,0"/>

                    <TextBlock Text="PASSWORD"
                               Foreground="#666666"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <PasswordBox x:Name="TxtPassword"
                                 Style="{StaticResource DarkPasswordBox}"
                                 Width="100"
                                 Margin="0,0,12,0"/>

                    <Button x:Name="BtnConnect"
                            Style="{StaticResource AccentButton}"
                            Content="Connetti"
                            Width="90"
                            Click="BtnConnect_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── AREA PRINCIPALE ────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Pannello sinistro scene + controlli -->
                <ColumnDefinition Width="220"/>
                <!-- Anteprima -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── PANNELLO SINISTRO ──────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="#141414"
                    BorderBrush="#333333"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,12,0,12">

                        <!-- Scene -->
                        <TextBlock Text="SCENE"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="14,0,14,8"/>
                        <ListBox x:Name="SceneListBox"
                                 Style="{StaticResource SceneListBox}"
                                 SelectionChanged="SceneListBox_SelectionChanged"
                                 MinHeight="120"
                                 FontSize="13"/>

                        <!-- Divisore -->
                        <Rectangle Height="1" Fill="#2A2A2A" Margin="14,16,14,16"/>

                        <!-- Virtual Camera -->
                        <TextBlock Text="VIRTUAL CAMERA"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="14,0"/>
                        <StackPanel Margin="14,0">
                            <Border Background="#1A1A1A"
                                    BorderBrush="#333333"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,10"
                                    Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="VCamDot"
                                             Width="8" Height="8"
                                             Fill="#555555"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtVCamStatus"
                                               Text="Inattiva"
                                               Foreground="#888888"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="BtnVirtualCam"
                                    Style="{StaticResource GhostButton}"
                                    Content="▶  Avvia Virtual Camera"
                                    Height="34"
                                    IsEnabled="False"
                                    Click="BtnVirtualCam_Click"/>
                        </StackPanel>

                        <!-- Divisore -->
                        <Rectangle Height="1" Fill="#2A2A2A" Margin="14,16,14,16"/>

                        <!-- Invia immagine -->
                        <TextBlock Text="INVIA IMMAGINE"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="14,0"/>
                        <StackPanel Margin="14,0">
                            <!-- Nome sorgente OBS -->
                            <TextBlock Text="Sorgente OBS (image_source)"
                                       Foreground="#666666"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtSourceName"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="ImageSource"
                                     Margin="0,0,0,10"/>

                            <!-- Percorso file -->
                            <TextBlock Text="File immagine"
                                       Foreground="#666666"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtImagePath"
                                         Grid.Column="0"
                                         Style="{StaticResource DarkTextBox}"
                                         IsReadOnly="True"
                                         Foreground="#666666"
                                         FontSize="11"
                                         Margin="0,0,4,0"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource GhostButton}"
                                        Content="…"
                                        Padding="0"
                                        Click="BtnBrowse_Click"/>
                            </Grid>

                            <!-- Anteprima thumbnail immagine selezionata -->
                            <Border x:Name="ThumbBorder"
                                    Background="#111111"
                                    BorderBrush="#333333"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Height="80"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                                <Image x:Name="ThumbImage"
                                       Stretch="Uniform"
                                       Margin="2"/>
                            </Border>

                            <Button x:Name="BtnSendImage"
                                    Style="{StaticResource AccentButton}"
                                    Content="↑  Invia a OBS"
                                    Height="34"
                                    IsEnabled="False"
                                    Click="BtnSendImage_Click"/>
                        </StackPanel>

                        <!-- Divisore -->
                        <Rectangle Height="1" Fill="#2A2A2A" Margin="14,16,14,16"/>

                        <!-- Refresh anteprima -->
                        <TextBlock Text="ANTEPRIMA"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="14,0"/>
                        <StackPanel Margin="14,0" Orientation="Horizontal">
                            <TextBlock Text="Aggiornamento:"
                                       Foreground="#666666"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <ComboBox x:Name="CmbRefreshRate"
                                      Background="#242424"
                                      Foreground="#E8E8E8"
                                      BorderBrush="#333333"
                                      Width="80"
                                      Height="26"
                                      FontSize="11"
                                      SelectionChanged="CmbRefreshRate_SelectionChanged">
                                <ComboBoxItem Content="0.5 s" Tag="500"/>
                                <ComboBoxItem Content="1 s"   Tag="1000" IsSelected="True"/>
                                <ComboBoxItem Content="2 s"   Tag="2000"/>
                                <ComboBoxItem Content="5 s"   Tag="5000"/>
                            </ComboBox>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── AREA ANTEPRIMA ──────────────────────────────────────── -->
            <Grid Grid.Column="1" Background="#0D0D0D">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Intestazione anteprima -->
                <Border Grid.Row="0"
                        Background="#141414"
                        BorderBrush="#333333"
                        BorderThickness="0,0,0,1"
                        Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="PROGRAM"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="#888888"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   LetterSpacing="2"/>
                        <TextBlock x:Name="TxtCurrentScene"
                                   FontSize="13"
                                   Foreground="#E8E8E8"
                                   VerticalAlignment="Center"/>
                        <Rectangle Width="1" Fill="#333333" Margin="12,8,12,8"/>
                        <TextBlock x:Name="TxtFps"
                                   Text="— fps"
                                   FontSize="11"
                                   Foreground="#555555"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Preview image -->
                <Border Grid.Row="1"
                        Margin="20"
                        Background="#000000"
                        CornerRadius="4">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20"
                                          ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Immagine di anteprima -->
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <!-- Placeholder quando non connesso -->
                        <StackPanel x:Name="PreviewPlaceholder"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="⬛"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Opacity="0.15"/>
                            <TextBlock Text="Connetti OBS per vedere l'anteprima"
                                       Foreground="#444444"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Overlay errore -->
                        <Border x:Name="ErrorOverlay"
                                Background="#CC000000"
                                Visibility="Collapsed"
                                CornerRadius="4">
                            <TextBlock x:Name="TxtError"
                                       Foreground="#FF6B35"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="20"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ── STATUS BAR ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#0A0A0A"
                BorderBrush="#222222"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBar"
                           Grid.Column="0"
                           Text="Non connesso  —  Avvia OBS, abilita il WebSocket Server (Strumenti → WebSocket Server Settings)"
                           Foreground="#555555"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTimestamp"
                           Grid.Column="1"
                           Foreground="#333333"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
