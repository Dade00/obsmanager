<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Icona dell'applicazione - rimuovere se non disponibile -->
    <!-- <ApplicationIcon>obs_icon.ico</ApplicationIcon> -->
    <AssemblyName>OBSController</AssemblyName>
    <RootNamespace>OBSController</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- OBS WebSocket v5 wrapper (OBS 28+) -->
    <PackageReference Include="obs-websocket-dotnet" Version="5.0.1" />
    <!-- JSON per SetInputSettings -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
